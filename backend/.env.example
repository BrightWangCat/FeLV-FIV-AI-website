# Required for JWT token signing (generate a random string for production)
SECRET_KEY=change-me-to-a-random-string

# Anthropic API key for AI classification (optional, CV pipeline works without it)
ANTHROPIC_API_KEY=

# Claude model for LLM classification
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Database URL (default: SQLite)
DATABASE_URL=sqlite:///./lfa_reader.db

# Upload directory path (default: ./uploads)
# UPLOAD_DIR=/path/to/uploads
